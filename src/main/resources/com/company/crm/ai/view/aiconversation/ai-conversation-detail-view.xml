<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://aiConversationDetailView.title">
    <data>
        <instance id="aiConversationDc"
                  class="com.company.crm.ai.model.AiConversation">
            <fetchPlan extends="_base">
                <property name="messages" fetchPlan="_base"/>
                <property name="attachments" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="aiConversationDl"/>
        </instance>
        <collection id="attachmentsDc"
                    class="com.company.crm.ai.model.AiConversationAttachment">
            <fetchPlan extends="_base"/>
            <loader id="attachmentsDl">
                <query>
                    <![CDATA[select e from AiConversationAttachment e where e.conversation.id = :conversationId order by e.createdDate desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <layout>
        <split id="conversationSplit" orientation="HORIZONTAL" width="100%" height="100%" splitterPosition="68">
            <vbox id="chatPanel" width="100%" height="100%" spacing="true" padding="true">
                <hbox id="conversationTitleLayout" spacing="false" alignItems="CENTER">
                    <h3 id="conversationTitle"
                        dataContainer="aiConversationDc"
                        property="title"
                        classNames="m-0"/>
                    <button id="editConversationTitleBtn"
                            icon="PENCIL"
                            themeNames="tertiary-inline small icon"
                            classNames="ms-xs"
                            ariaLabel="msg://editConversationTitleAction"/>
                </hbox>
            </vbox>
            <vbox id="attachmentsPanel" width="100%" height="100%" spacing="false" padding="true">
                <h3 id="attachmentsTitle"
                    text="msg://com.company.crm.ai.view.aiconversation/attachmentsPanelTitle"
                    classNames="m-0"/>
                <gridLayout id="attachmentsGridLayout"
                            itemsContainer="attachmentsDc"
                            width="100%"
                            gap="var(--lumo-space-xs)">
                    <fragmentRenderer class="com.company.crm.ai.view.aiconversation.AiAttachmentCardFragmentRenderer"/>
                </gridLayout>
                <upload id="attachmentUpload"
                        width="100%"
                        classNames="attachments-dropzone"
                        acceptedFileTypes=".pdf,.csv,.doc,.docx,.xls,.xlsx,.html,.htm,.txt,.md,.png,.jpg,.jpeg,.gif,.webp"
                        uploadText="msg://com.company.crm.ai.view.aiconversation/attachmentUploadField.uploadText"
                        dropLabel="msg://com.company.crm.ai.view.aiconversation/attachmentUpload.dropLabel"
                        dropAllowed="true"
                        receiverType="FILE_TEMPORARY_STORAGE_BUFFER"
                        maxFiles="1"/>
            </vbox>
        </split>
    </layout>
</view>
