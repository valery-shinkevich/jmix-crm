<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<fragment xmlns="http://jmix.io/schema/flowui/fragment">
    <data readOnly="true">
        <instance id="attachmentDc"
                  class="com.company.crm.ai.model.AiConversationAttachment"/>
    </data>
    <content>
        <card id="attachmentCard" width="100%" themeNames="outlined">
            <headerPrefix>
                <icon id="attachmentIcon" icon="FILE_O" size="S"/>
            </headerPrefix>
            <header>
                <h5 id="titleValue"
                    dataContainer="attachmentDc"
                    property="title"/>
            </header>
            <headerSuffix>
                <button id="openButton"
                        icon="EXTERNAL_LINK"
                        themeNames="tertiary-inline small icon"/>
            </headerSuffix>
            <content>
                <hbox id="metaLayout"
                      spacing="true"
                      alignItems="CENTER"
                      classNames="attachment-card-meta">
                    <span id="timestampValue"
                          dataContainer="attachmentDc"
                          property="createdDate"
                          classNames="text-secondary text-s"/>
                    <span id="sourceSeparator"
                          text="|"
                          classNames="text-secondary text-s attachment-card-meta-separator"/>
                    <icon id="sourceIcon"
                          icon="QUESTION_CIRCLE_O"
                          size="S"
                          classNames="attachment-card-source-icon"/>
                    <span id="sourceValue"
                          classNames="text-secondary text-s attachment-card-source-text"/>
                </hbox>
            </content>
        </card>
    </content>
</fragment>
